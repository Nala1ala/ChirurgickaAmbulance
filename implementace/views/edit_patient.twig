{# views/edit_patient.twig #}
{% extends 'base.twig' %}

{% block title %}Úprava pacienta - {{ patient.getGivenName() }} {{ patient.getSurname() }}{% endblock %}

{% block content %}
    <div class="row justify-content-center mt-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Úprava osobních údajů</h4>
                </div>

                <div class="card-body">
                    <form action="index.php?action=edit_patient&id={{ patient.getBirthCertificateNumber() }}" method="POST">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Rodné číslo (nelze měnit)</label>
                                <input type="text" class="form-control bg-light" value="{{ patient.getBirthCertificateNumber() | striptags }}" readonly>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="birthdate" class="form-label fw-bold">Datum narození (nelze měnit)</label>
                                <input type="date" class="form-control bg-light" id="birthdate" name="birthdate" value="{{ patient.getBirthdate() }}" readonly>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="givenName" class="form-label fw-bold">Jméno *</label>
                                <input type="text" class="form-control" id="givenName" name="givenName" value="{{ patient.getGivenName() | striptags }}" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="surname" class="form-label fw-bold">Příjmení *</label>
                                <input type="text" class="form-control" id="surname" name="surname" value="{{ patient.getSurname() | striptags }}" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="insuranceCompanyNumber" class="form-label fw-bold">Kód pojišťovny *</label>
                                <input type="number" class="form-control" id="insuranceCompanyNumber" name="insuranceCompanyNumber" value="{{ patient.getInsuranceCompanyNumber() }}" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="phoneNumber" class="form-label fw-bold">Telefonní číslo *</label>
                                <input type="text" class="form-control" id="phoneNumber" name="phoneNumber" value="{{ patient.getPhoneNumber() | striptags }}" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="address" class="form-label fw-bold">Trvalé bydliště *</label>
                            <input type="text" class="form-control" id="address" name="address" value="{{ patient.getAddress() | striptags }}" required>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3 mt-4">
                            <a href="index.php?action=detail&id={{ patient.getBirthCertificateNumber() }}" class="btn btn-outline-secondary">Zrušit a zpět</a>
                            <button type="submit" class="btn btn-primary">Uložit změny</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}